From a59389d6f12e3df0bcf594df6e24042fec003da4 Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Sun, 8 Dec 2024 22:54:59 +0100
Subject: [PATCH] backport uvm warning fixes from 560.28.03

---
 nvidia-uvm/uvm8_kepler_mmu.c     | 1 +
 nvidia-uvm/uvm8_page_tree_test.c | 2 +-
 nvidia-uvm/uvm8_pascal_mmu.c     | 1 +
 3 files changed, 3 insertions(+), 1 deletion(-)

diff --git a/nvidia-uvm/uvm8_kepler_mmu.c b/nvidia-uvm/uvm8_kepler_mmu.c
index e49cf73d..2e06e513 100644
--- a/nvidia-uvm/uvm8_kepler_mmu.c
+++ b/nvidia-uvm/uvm8_kepler_mmu.c
@@ -38,6 +38,7 @@
 #include "uvm8_forward_decl.h"
 #include "uvm8_gpu.h"
 #include "uvm8_mmu.h"
+#include "uvm8_hal.h"
 #include "uvm8_push_macros.h"
 #include "hwref/kepler/gk104/dev_mmu.h"
 
diff --git a/nvidia-uvm/uvm8_page_tree_test.c b/nvidia-uvm/uvm8_page_tree_test.c
index 69f34ad0..ac07b768 100644
--- a/nvidia-uvm/uvm8_page_tree_test.c
+++ b/nvidia-uvm/uvm8_page_tree_test.c
@@ -1427,7 +1427,7 @@ static uvm_mmu_page_table_alloc_t fake_table_alloc(uvm_aperture_t aperture, NvU6
 // Queries the supported page sizes of the GPU(uvm_gpu_t) and fills the
 // page_sizes array up to MAX_NUM_PAGE_SIZE. Returns the number of elements in
 // page_sizes;
-size_t get_page_sizes(uvm_gpu_t *gpu, NvU32 *page_sizes)
+static size_t get_page_sizes(uvm_gpu_t *gpu, NvU32 *page_sizes)
 {
     unsigned long page_size_log2;
     unsigned long page_sizes_bitvec;
diff --git a/nvidia-uvm/uvm8_pascal_mmu.c b/nvidia-uvm/uvm8_pascal_mmu.c
index 90250051..8a88826f 100644
--- a/nvidia-uvm/uvm8_pascal_mmu.c
+++ b/nvidia-uvm/uvm8_pascal_mmu.c
@@ -36,6 +36,7 @@
 #include "uvm8_global.h"
 #include "uvm8_gpu.h"
 #include "uvm8_mmu.h"
+#include "uvm8_hal.h"
 #include "uvm8_push_macros.h"
 #include "uvm8_pascal_fault_buffer.h"
 #include "hwref/pascal/gp100/dev_fault.h"
