From ad3ee65c1bdf83da1b5574cf02022dbf03b43d67 Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Tue, 27 Jan 2026 18:09:15 +0100
Subject: [PATCH] backport nv_in_hardirq changes from 580.119.02

---
 common/inc/nv-time.h  | 14 ++++++++++++++
 nvidia/linux_nvswitch.c |  2 +-
 nvidia/nvlink_linux.c |  2 +-
 nvidia/os-interface.c |  6 +++---
 4 files changed, 19 insertions(+), 5 deletions(-)

diff --git a/common/inc/nv-time.h b/common/inc/nv-time.h
index baa77825..988510f1 100644
--- a/common/inc/nv-time.h
+++ b/common/inc/nv-time.h
@@ -45,6 +45,20 @@ static inline s64 timespec64_to_ns(struct timespec64 *ts)
 }
 #endif
 
+/*
+ * in_hardirq() was added in v5.11-rc1 (2020-12-15) to replace in_irq().
+ * Fall back to in_irq() for older kernels that don't have in_hardirq().
+ */
+#include <linux/hardirq.h>
+static inline NvBool nv_in_hardirq(void)
+{
+#if defined(in_hardirq)
+    return in_hardirq();
+#else
+    return in_irq();
+#endif
+}
+
 #if !defined(NV_KTIME_GET_RAW_TS64_PRESENT)
 static inline void ktime_get_raw_ts64(struct timespec64 *ts64)
 {
diff --git a/nvidia/linux_nvswitch.c b/nvidia/linux_nvswitch.c
index b48254fe..2c616689 100644
--- a/nvidia/linux_nvswitch.c
+++ b/nvidia/linux_nvswitch.c
@@ -2457,7 +2457,7 @@ nvswitch_os_sleep
 
     nv_gettimeofday(&tm_aux);
 
-    if (in_irq() && (ms > NV_MAX_ISR_DELAY_MS))
+    if (nv_in_hardirq() && (ms > NV_MAX_ISR_DELAY_MS))
     {
         return;
     }
diff --git a/nvidia/nvlink_linux.c b/nvidia/nvlink_linux.c
index 22ee3ee7..20ce98c6 100644
--- a/nvidia/nvlink_linux.c
+++ b/nvidia/nvlink_linux.c
@@ -600,7 +600,7 @@ void NVLINK_API_CALL nvlink_sleep(unsigned int ms)
 
     nv_gettimeofday(&tm_aux);
 
-    if (in_irq() && (ms > NV_MAX_ISR_DELAY_MS))
+    if (nv_in_hardirq() && (ms > NV_MAX_ISR_DELAY_MS))
     {
         return;
     }
diff --git a/nvidia/os-interface.c b/nvidia/os-interface.c
index dd818810..bec97d0d 100644
--- a/nvidia/os-interface.c
+++ b/nvidia/os-interface.c
@@ -223,7 +223,7 @@ BOOL NV_API_CALL os_semaphore_may_sleep(void)
 
 BOOL NV_API_CALL os_is_isr(void)
 {
-    return (in_irq());
+    return (nv_in_hardirq());
 }
 
 // return TRUE if the caller is the super-user
@@ -630,7 +630,7 @@ NV_STATUS NV_API_CALL os_delay_us(NvU32 MicroSeconds)
     nv_gettimeofday(&tm1);
 #endif
 
-    if (in_irq() && (MicroSeconds > NV_MAX_ISR_DELAY_US))
+    if (nv_in_hardirq() && (MicroSeconds > NV_MAX_ISR_DELAY_US))
         return NV_ERR_GENERIC;
 
     mdelay_safe_msec = MicroSeconds / 1000;
@@ -674,7 +674,7 @@ NV_STATUS NV_API_CALL os_delay(NvU32 MilliSeconds)
     tm_start = tm_aux;
 #endif
 
-    if (in_irq() && (MilliSeconds > NV_MAX_ISR_DELAY_MS))
+    if (nv_in_hardirq() && (MilliSeconds > NV_MAX_ISR_DELAY_MS))
         return NV_ERR_GENERIC;
 
     if (!NV_MAY_SLEEP())
-- 
2.39.5

