Author: Andreas Beckmann <anbe@debian.org>
Description: use KBUILD_CFLAGS
 allows building a amd64 kernel module with i386 user space
 skip -Werror=* since that breaks how conftest.sh detects stuff

--- a/conftest.sh
+++ b/conftest.sh
@@ -294,6 +294,14 @@ build_cflags() {
             CFLAGS="$CFLAGS -DCC_HAVE_ASM_GOTO"
         fi
     fi
+
+    for flag in $KBUILD_CFLAGS
+    do
+        case $flag in
+            -Werror*)   ;;
+            *)          CFLAGS="$CFLAGS $flag" ;;
+        esac
+    done
 }
 
 CONFTEST_PREAMBLE="#include \"conftest.h\"
--- a/nvidia-modules-common.mk
+++ b/nvidia-modules-common.mk
@@ -109,7 +109,12 @@ ifndef nvkARCH
  )
 endif
 
-CONFTEST := /bin/sh $(src)/conftest.sh "$(strip $(CC))" "$(strip $(HOST_CC))" $(nvkARCH) $(KERNEL_SOURCES) $(KERNEL_OUTPUT)
+NV_CONFTEST_CFLAGS += $(call cc-option,-Wno-error=implicit-function-declaration,)
+NV_CONFTEST_CFLAGS += $(call cc-option,-Wno-error=incompatible-pointer-types,)
+NV_CONFTEST_CFLAGS += $(call cc-option,-Wno-error=return-type,)
+NV_CONFTEST_CFLAGS += $(call cc-option,-Wno-error=strict-prototypes,)
+
+CONFTEST := /bin/sh $(src)/conftest.sh "$(strip $(CC) $(NV_CONFTEST_CFLAGS))" "$(strip $(HOST_CC))" $(nvkARCH) $(KERNEL_SOURCES) $(KERNEL_OUTPUT)
 
 MODULE_ROOT := /lib/modules/$(KERNEL_UNAME)/kernel/drivers
 
