From 1857da7fe2051273de922fe92c06896295dc8d2a Mon Sep 17 00:00:00 2001
From: lichenggang <lichenggang@deepin.org>
Date: Mon, 21 Jul 2025 20:22:24 +0800
Subject: [PATCH] 0001-Make-modeset-and-fbdev-default-enabled.patch

---
 kernel-open/nvidia-drm/nvidia-drm-linux.c        | 2 +-
 kernel-open/nvidia-drm/nvidia-drm-os-interface.c | 2 +-
 kernel/nvidia-drm/nvidia-drm-linux.c             | 2 +-
 kernel/nvidia-drm/nvidia-drm-os-interface.c      | 2 +-
 4 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/NVIDIA-Linux/kernel-open/nvidia-drm/nvidia-drm-linux.c b/NVIDIA-Linux/kernel-open/nvidia-drm/nvidia-drm-linux.c
index 3cb1815..209cb46 100644
--- a/NVIDIA-Linux/kernel-open/nvidia-drm/nvidia-drm-linux.c
+++ b/NVIDIA-Linux/kernel-open/nvidia-drm/nvidia-drm-linux.c
@@ -31,7 +31,7 @@
 
 MODULE_PARM_DESC(
     modeset,
-    "Enable atomic kernel modesetting (1 = enable, 0 = disable (default))");
+    "Enable atomic kernel modesetting (1 = enable (default), 0 = disable)");
 module_param_named(modeset, nv_drm_modeset_module_param, bool, 0400);
 
 #if defined(NV_DRM_FBDEV_AVAILABLE)
diff --git a/NVIDIA-Linux/kernel-open/nvidia-drm/nvidia-drm-os-interface.c b/NVIDIA-Linux/kernel-open/nvidia-drm/nvidia-drm-os-interface.c
index c7eb797..bcf0fd3 100644
--- a/NVIDIA-Linux/kernel-open/nvidia-drm/nvidia-drm-os-interface.c
+++ b/NVIDIA-Linux/kernel-open/nvidia-drm/nvidia-drm-os-interface.c
@@ -41,7 +41,7 @@
 #include <drm/drmP.h>
 #endif
 
-bool nv_drm_modeset_module_param = false;
+bool nv_drm_modeset_module_param = true;
 bool nv_drm_fbdev_module_param = true;
 
 void *nv_drm_calloc(size_t nmemb, size_t size)
diff --git a/NVIDIA-Linux/kernel/nvidia-drm/nvidia-drm-linux.c b/NVIDIA-Linux/kernel/nvidia-drm/nvidia-drm-linux.c
index 0007cbf..bd0b9eb 100644
--- a/NVIDIA-Linux/kernel/nvidia-drm/nvidia-drm-linux.c
+++ b/NVIDIA-Linux/kernel/nvidia-drm/nvidia-drm-linux.c
@@ -31,7 +31,7 @@
 
 MODULE_PARM_DESC(
     modeset,
-    "Enable atomic kernel modesetting (1 = enable, 0 = disable (default))");
+    "Enable atomic kernel modesetting (1 = enable (default), 0 = disable)");
 module_param_named(modeset, nv_drm_modeset_module_param, bool, 0400);
 
 #if defined(NV_DRM_FBDEV_AVAILABLE)
diff --git a/NVIDIA-Linux/kernel/nvidia-drm/nvidia-drm-os-interface.c b/NVIDIA-Linux/kernel/nvidia-drm/nvidia-drm-os-interface.c
index c7eb797..bcf0fd3 100644
--- a/NVIDIA-Linux/kernel/nvidia-drm/nvidia-drm-os-interface.c
+++ b/NVIDIA-Linux/kernel/nvidia-drm/nvidia-drm-os-interface.c
@@ -41,7 +41,7 @@
 #include <drm/drmP.h>
 #endif
 
-bool nv_drm_modeset_module_param = false;
+bool nv_drm_modeset_module_param = true;
 bool nv_drm_fbdev_module_param = true;
 
 void *nv_drm_calloc(size_t nmemb, size_t size)
-- 
2.47.2

