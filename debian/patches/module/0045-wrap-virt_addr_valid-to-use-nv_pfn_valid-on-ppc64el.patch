From 73f6b385d2599f64262389f19d48b53b1b887c0d Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Mon, 24 Jun 2024 02:31:03 +0200
Subject: [PATCH] wrap virt_addr_valid() to use nv_pfn_valid() on ppc64el

---
 common/inc/nv-linux.h | 11 +++++++++++
 nvidia-uvm/uvm_mem.c  |  2 +-
 nvidia/nv-vtophys.c   |  2 +-
 3 files changed, 13 insertions(+), 2 deletions(-)

diff --git a/common/inc/nv-linux.h b/common/inc/nv-linux.h
index 8277bd4..63ae6b1 100644
--- a/common/inc/nv-linux.h
+++ b/common/inc/nv-linux.h
@@ -2084,8 +2084,19 @@ static inline int nv_pfn_valid(unsigned long pfn)
         return ret;
 }
 
+#if defined(NVCPU_PPC64LE)
+#define nv_virt_addr_valid(vaddr)  ({                                   \
+        unsigned long _addr = (unsigned long)vaddr;                     \
+        _addr >= PAGE_OFFSET && _addr < (unsigned long)high_memory &&   \
+        nv_pfn_valid(virt_to_pfn(_addr));                               \
+})
+#else
+#  define nv_virt_addr_valid virt_addr_valid
+#endif
+
 #else
 #  define nv_pfn_valid pfn_valid
+#  define nv_virt_addr_valid virt_addr_valid
 #endif
 
 #define NV_CHECK_EXPORT_SYMBOL(symbol)  (NV_IS_EXPORT_SYMBOL_PRESENT_##symbol && \
diff --git a/nvidia-uvm/uvm_mem.c b/nvidia-uvm/uvm_mem.c
index 460f786..2182796 100644
--- a/nvidia-uvm/uvm_mem.c
+++ b/nvidia-uvm/uvm_mem.c
@@ -276,7 +276,7 @@ NV_STATUS uvm_mem_translate_gpu_attributes(const UvmGpuMappingAttributes *attrs,
 
 static struct page *uvm_virt_to_page(const void *addr)
 {
-    if (virt_addr_valid(addr))
+    if (nv_virt_addr_valid(addr))
         return virt_to_page(addr);
 
     if (is_vmalloc_addr(addr))
diff --git a/nvidia/nv-vtophys.c b/nvidia/nv-vtophys.c
index df2a01e..8d30d72 100644
--- a/nvidia/nv-vtophys.c
+++ b/nvidia/nv-vtophys.c
@@ -29,7 +29,7 @@
 NvU64 NV_API_CALL nv_get_kern_phys_address(NvU64 address)
 {
     /* direct-mapped kernel address */
-    if (virt_addr_valid(address))
+    if (nv_virt_addr_valid(address))
         return __pa(address);
 
     nv_printf(NV_DBG_ERRORS,
-- 
2.20.1

