From 4b4b57c33e48c9c2b72a63235415dfb7c20bda22 Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Sun, 8 Dec 2024 22:13:22 +0100
Subject: [PATCH] fix more warnings

---
 common/inc/nv-linux.h       | 8 ++++++++
 nvidia-drm/nvidia-drm-drv.c | 2 ++
 4 files changed, 13 insertions(+), 1 deletion(-)

diff --git a/common/inc/nv-linux.h b/common/inc/nv-linux.h
index cb500002..811b55d5 100644
--- a/common/inc/nv-linux.h
+++ b/common/inc/nv-linux.h
@@ -575,21 +575,27 @@ static NvBool nv_numa_node_has_memory(int node_id)
     { \
         (ptr) = kmalloc(size, NV_GFP_KERNEL); \
         if (ptr) \
+        { \
             NV_MEMDBG_ADD(ptr, size); \
+        } \
     }
 
 #define NV_KZALLOC(ptr, size) \
     { \
         (ptr) = kzalloc(size, NV_GFP_KERNEL); \
         if (ptr) \
+        { \
             NV_MEMDBG_ADD(ptr, size); \
+        } \
     }
 
 #define NV_KMALLOC_ATOMIC(ptr, size) \
     { \
         (ptr) = kmalloc(size, NV_GFP_ATOMIC); \
         if (ptr) \
+        { \
             NV_MEMDBG_ADD(ptr, size); \
+        } \
     }
 
 #if defined(__GFP_RETRY_MAYFAIL)
@@ -604,7 +610,9 @@ static NvBool nv_numa_node_has_memory(int node_id)
     { \
         (ptr) = kmalloc(size, NV_GFP_NO_OOM); \
         if (ptr) \
+        { \
             NV_MEMDBG_ADD(ptr, size); \
+        } \
     }
 
 #define NV_KFREE(ptr, size) \
diff --git a/nvidia-drm/nvidia-drm-drv.c b/nvidia-drm/nvidia-drm-drv.c
index 2b0d5d36..fe839f39 100644
--- a/nvidia-drm/nvidia-drm-drv.c
+++ b/nvidia-drm/nvidia-drm-drv.c
@@ -1751,12 +1751,14 @@ void nv_drm_register_drm_device(const nv_gpu_info_t *gpu_info)
     dev->dev_private = nv_dev;
     nv_dev->dev = dev;
 
+#if defined(NV_DRM_DEVICE_HAS_PDEV) || defined(NV_DRM_FBDEV_GENERIC_AVAILABLE)
     bool bus_is_pci =
 #if defined(NV_LINUX)
         device->bus == &pci_bus_type;
 #elif defined(NV_BSD)
         devclass_find("pci");
 #endif
+#endif
 
 #if defined(NV_DRM_DEVICE_HAS_PDEV)
     if (bus_is_pci) {
-- 
2.39.5

