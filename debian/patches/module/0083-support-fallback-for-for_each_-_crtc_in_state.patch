From 4bffbbcc29eea9857b8392b90e10105f13a6ce2a Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Wed, 28 Jan 2026 15:53:49 +0100
Subject: [PATCH 4/4] support fallback for for_each_*_crtc_in_state

---
 nvidia-drm/nvidia-drm-crtc.c    |  4 ++--
 nvidia-drm/nvidia-drm-helper.h  | 20 ++++++++++++++++++++
 nvidia-drm/nvidia-drm-modeset.c | 10 +++++-----
 3 files changed, 27 insertions(+), 7 deletions(-)

diff --git a/nvidia-drm/nvidia-drm-crtc.c b/nvidia-drm/nvidia-drm-crtc.c
index f386d34c..6224cfbc 100644
--- a/nvidia-drm/nvidia-drm-crtc.c
+++ b/nvidia-drm/nvidia-drm-crtc.c
@@ -563,7 +563,7 @@ static int __nv_drm_cursor_atomic_check(struct drm_plane *plane,
 
     WARN_ON(nv_plane->layer_idx != NVKMS_KAPI_LAYER_INVALID_IDX);
 
-    for_each_new_crtc_in_state(plane_state->state, crtc, crtc_state, i) {
+    nv_drm_for_each_new_crtc_in_state(plane_state->state, crtc, crtc_state, i) {
         struct nv_drm_crtc_state *nv_crtc_state = to_nv_crtc_state(crtc_state);
         struct NvKmsKapiHeadRequestedConfig *head_req_config =
             &nv_crtc_state->req_config;
@@ -609,7 +609,7 @@ static int nv_drm_plane_atomic_check(struct drm_plane *plane,
 
     WARN_ON(nv_plane->layer_idx == NVKMS_KAPI_LAYER_INVALID_IDX);
 
-    for_each_new_crtc_in_state(plane_state->state, crtc, crtc_state, i) {
+    nv_drm_for_each_new_crtc_in_state(plane_state->state, crtc, crtc_state, i) {
         struct nv_drm_crtc_state *nv_crtc_state = to_nv_crtc_state(crtc_state);
         struct NvKmsKapiHeadRequestedConfig *head_req_config =
             &nv_crtc_state->req_config;
diff --git a/nvidia-drm/nvidia-drm-helper.h b/nvidia-drm/nvidia-drm-helper.h
index 77883f89..958326af 100644
--- a/nvidia-drm/nvidia-drm-helper.h
+++ b/nvidia-drm/nvidia-drm-helper.h
@@ -287,6 +287,26 @@ int nv_drm_atomic_helper_disable_all(struct drm_device *dev,
     for_each_crtc_in_state(__state, crtc, crtc_state, __i)
 #endif
 
+#if defined(for_each_new_crtc_in_state)
+#define nv_drm_for_each_new_crtc_in_state for_each_new_crtc_in_state
+#else
+#define nv_drm_for_each_new_crtc_in_state nv_drm_for_each_crtc_in_state
+#endif
+
+#if defined(for_each_old_crtc_in_state)
+#define nv_drm_for_each_old_crtc_in_state for_each_old_crtc_in_state
+#else
+#define nv_drm_for_each_old_crtc_in_state nv_drm_for_each_crtc_in_state
+#endif
+
+#if defined(for_each_oldnew_crtc_in_state)
+#define nv_drm_for_each_oldnew_crtc_in_state for_each_oldnew_crtc_in_state
+#else
+// this is probably insufficient
+#define nv_drm_for_each_oldnew_crtc_in_state(__state, crtc, old_crtc_state, new_crtc_state, __i) \
+	nv_drm_for_each_new_crtc_in_state(__state, crtc, new_crtc_state, __i)
+#endif
+
 /**
  * nv_drm_for_each_plane_in_state - iterate over all planes in an atomic update
  * @__state: &struct drm_atomic_state pointer
diff --git a/nvidia-drm/nvidia-drm-modeset.c b/nvidia-drm/nvidia-drm-modeset.c
index 8697435e..c6488cd6 100644
--- a/nvidia-drm/nvidia-drm-modeset.c
+++ b/nvidia-drm/nvidia-drm-modeset.c
@@ -252,7 +252,7 @@ nv_drm_atomic_apply_modeset_config(struct drm_device *dev,
     memset(requested_config, 0, sizeof(*requested_config));
 
     /* Loop over affected crtcs and construct NvKmsKapiRequestedModeSetConfig */
-    for_each_oldnew_crtc_in_state(state, crtc, old_crtc_state, new_crtc_state, i) {
+    nv_drm_for_each_oldnew_crtc_in_state(state, crtc, old_crtc_state, new_crtc_state, i) {
         struct nv_drm_crtc *nv_crtc = to_nv_crtc(crtc);
 
         requested_config->headRequestedConfig[nv_crtc->head] =
@@ -300,7 +300,7 @@ nv_drm_atomic_apply_modeset_config(struct drm_device *dev,
 
     if (commit && nv_dev->supportsSyncpts) {
         /* commit is true so we check old state */
-        for_each_old_crtc_in_state(state, crtc, old_crtc_state, i) {
+        nv_drm_for_each_old_crtc_in_state(state, crtc, old_crtc_state, i) {
             /*! loop over affected crtcs and get NvKmsKapiModeSetReplyConfig */
             ret = __nv_drm_get_syncpt_data(
                       nv_dev, crtc, old_crtc_state, requested_config, &reply_config);
@@ -323,7 +323,7 @@ int nv_drm_atomic_check(struct drm_device *dev,
     struct drm_crtc_state *crtc_state;
     int i;
 
-    for_each_new_crtc_in_state(state, crtc, crtc_state, i) {
+    nv_drm_for_each_new_crtc_in_state(state, crtc, crtc_state, i) {
         /*
          * if the color management changed on the crtc, we need to update the
          * crtc's plane's CSC matrices, so add the crtc's planes to the commit
@@ -420,7 +420,7 @@ int nv_drm_atomic_commit(struct drm_device *dev,
      * Our system already implements such a queue, but due to
      * bug 4054608, it is currently not used.
      */
-    for_each_new_crtc_in_state(state, crtc, crtc_state, i) {
+    nv_drm_for_each_new_crtc_in_state(state, crtc, crtc_state, i) {
         struct nv_drm_crtc *nv_crtc = to_nv_crtc(crtc);
 
         /*
@@ -505,7 +505,7 @@ int nv_drm_atomic_commit(struct drm_device *dev,
     }
     nv_dev->drmMasterChangedSinceLastAtomicCommit = NV_FALSE;
 
-    for_each_old_crtc_in_state(state, crtc, crtc_state, i) {
+    nv_drm_for_each_old_crtc_in_state(state, crtc, crtc_state, i) {
         struct nv_drm_crtc *nv_crtc = to_nv_crtc(crtc);
         struct nv_drm_crtc_state *nv_new_crtc_state =
             to_nv_crtc_state(crtc->state);
-- 
2.39.5

